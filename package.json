{
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:turbopack": "turbo build --env-mode=loose",
    "dev": "turbo dev",
    "dev:turbopack": "turbo dev --env-mode=loose",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "type-check": "turbo check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "5.8.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19",
      "@types/react-dom": "^19",
      "form-data": ">=4.0.4"
    }
  }
}
